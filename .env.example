# ==========================================
# EXECUTABLE ENVIRONMENT TEMPLATE
# Copy to `.env` before booting application.
# Project-root .env is loaded by python-dotenv (Stage 4) and the FastAPI app.
# ==========================================

# ------------------------------------------------------------
# Stage 1+2 — DeBERTa local weights
# ------------------------------------------------------------
LOCAL_MODEL_PATH="./models/stage1_2_deberta"

# ------------------------------------------------------------
# Stage 3 — Ollama (Mistral agent) + embeddings
# ------------------------------------------------------------
OLLAMA_HOST="http://localhost:11434"
OLLAMA_EMBED_MODEL="all-minilm"

# ------------------------------------------------------------
# Stage 4 — Gemini Flash explainer + executive summary
# Get a free key at: https://aistudio.google.com/app/apikey
# Free tier: ~15 requests per minute (we cap at 12 in
# configs/stage4_config.yaml :: gemini.rate_limit_rpm).
# ------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — override the default model (otherwise uses the value
# from configs/stage4_config.yaml :: gemini.model).
# GEMINI_MODEL=gemini-1.5-flash
