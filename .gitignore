# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ============================================================
# Testing & Coverage
# ============================================================
.pytest_cache/
htmlcov/
.coverage
.coverage.*
pytest.xml

# ============================================================
# Virtual Environments & Package Managers
# ============================================================
.venv/
env/
venv/
ENV/
.uv/

# ============================================================
# Environment Config
# ⚠️  .env holds secrets — NEVER commit it. Use .env.example
# ============================================================
.env
!.env.example

# ============================================================
# Jupyter Notebooks
# ============================================================
.ipynb_checkpoints/
*.ipynb

# ============================================================
# Logs
# ============================================================
*.log
logs/

# ============================================================
# macOS
# ============================================================
.DS_Store
.AppleDouble
.LSOverride

# ============================================================
# IDEs & Editors
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*.suo

# ============================================================
# ML Model Weights
# ⚠️  These are large binary files — distribute via DVC or shared drive
# ============================================================
*.pt
*.pth
*.safetensors
*.bin
*.onnx
*.pkl
*.h5
*.ckpt

# Ignore the entire local DeBERTa model directory
stage1_2_deberta/

# ============================================================
# Data Directories
# Track folder structure via .gitkeep, ignore actual content
# ============================================================
data/raw/*
!data/raw/.gitkeep

data/processed/*
!data/processed/.gitkeep

data/synthetic/*
!data/synthetic/.gitkeep

# ============================================================
# Build / Distribution
# ============================================================
dist/
build/
*.egg-info/
*.egg
.eggs/

# ============================================================
# Misc Output & Temp Files
# ============================================================

tmp/
temp/
*.tmp
